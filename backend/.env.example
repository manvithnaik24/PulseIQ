# ============================================================
# PulseIQ Backend — Environment Variables
# ============================================================
# Copy this file to .env for local development
# NEVER commit .env or .env.production to version control
# ============================================================

# ── Server ──────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
ENVIRONMENT=development

# ── Database ─────────────────────────────────────────────────
# PostgreSQL (Neon, Render, Supabase, etc.)
# Format: postgresql://user:password@host:port/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@your-neon-host.neon.tech/dbname?sslmode=require

# SQLite fallback for local-only testing (no server required)
# DATABASE_URL=sqlite:///./pulseiq.db

# ── Clerk Authentication ─────────────────────────────────────
# Get JWKS URL from: Clerk Dashboard → API Keys → Show JWT Templates → JWKS URL
CLERK_JWKS_URL=https://your-clerk-instance.clerk.accounts.dev/.well-known/jwks.json

# Get Webhook Secret from: Clerk Dashboard → Webhooks → Signing Secret
CLERK_WEBHOOK_SECRET=whsec_your_clerk_webhook_signing_secret_here

# ── AI Providers ─────────────────────────────────────────────
# Google AI Studio: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Groq Cloud: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# ── Security ─────────────────────────────────────────────────
# Generate a strong random key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_64_character_random_secret_key_here

# ── CORS Origins (comma-separated list if needed) ────────────
# CORS_ORIGINS=http://localhost:5173,https://your-production-domain.com

# ── Twilio SMS (Optional — for real SOS SMS alerts) ──────────
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_FROM_NUMBER=+1234567890

# ── Resend Email (Optional — for email notifications) ─────────
RESEND_API_KEY=re_your_resend_api_key_here
RESEND_FROM_EMAIL=noreply@yourdomain.com
